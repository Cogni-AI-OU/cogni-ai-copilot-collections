flowchart TD
    Start([New Objective Received]) --> Boot[Initialization Sequence]

    subgraph GLOBAL_AGENTS_md [AGENTS.md: Global Contract]
        direction TB
        B1["1- Agent Contract Alignment"]
        B2["2- Skill & Instruction Loading"]
        B3{"3- Submodules Initialized?"}
        B3 -->|No| B3a["git submodule update --init"]
        B3a --> B2
        B2 --> FL1
        FL6 --> CL1
        CL6 --> IL1
        IL6 --> SL1
        SL8 --> B3
    end

    Boot --> GLOBAL_AGENTS_md
    GLOBAL_AGENTS_md --> B4

    subgraph LOCAL_CONTRACT [elite.agent.md: Local Framework]
        B4["4- Context Verification"]
        B5["5- Context Intake: Memory and Trackers"]
        B6["6- Pre-Flight Snapshot: Entropy-Minimized Sentence"]
        B7["7- Strategy Initialization: Design-It-Twice and #todos"]
        B8["8- Task Refinement: Atomic Decomposition"]

        B8 --> Phase0[Phase 0: Intent and Architecture]

        Phase0 --> P0a[Task Triage and Context Economy]
        Phase0 --> P0b[Adversarial Constraint Analysis: Top-10 Risks]
        Phase0 --> P0c[Pre-Flight Snapshot Broadcast]
        Phase0 --> P0d[Session Resumption Engine]
        Phase0 --> P0e[Tracer-Bullet Planning]
        Phase0 --> P0f[Visual Architecture Charting]

        Phase1[Phase 1: Execution and Instrumentation]
        Phase1 --> P1a[Atomic Implementation: Deep Modules and Info Hiding]
        Phase1 --> P1b["Continuous State Inspection (DbC)"]
        Phase1 --> P1c[Surgical Precision: Read-Match-Edit Pattern]
        Phase1 --> P1d["Single-Variable Meta-Optimization"]

        P1d --> Cognitive{Cognitive Checkpoint}
        Cognitive -->|Per 8-Step Batch| MiniCP[Mini-Checkpoint: Verify Invariants]
        Cognitive -->|Every 5-8 Steps| HardCP[Hard Checkpoint: Re-Serialize State]
        MiniCP --> Contradiction{Contradiction Detected?}
        HardCP --> Contradiction

        Contradiction -->|Yes| Rewind[Metacognitive Rewind Protocol: Discard Downstream Trace]
        Rewind --> P1a
        Contradiction -->|No| EscalateCheck{Escalation Required?}

        Phase2[Phase 2: Verification and Assurance]
        Phase2 --> P2a[Narrowest Scope Verification]
        Phase2 --> P2b[Blast-Radius Audit: Regressions and Edge Cases]
        Phase2 --> P2c[QA Perfection Gate: Lint, Format, Security]
        Phase2 --> QAPass{All Gates Passed?}

        QAPass -->|No| Signal[Signal Extraction: Root-Cause Ablation]
        Signal --> P1a
        QAPass -->|Yes| TodosCheck{"Empirical Completion: 100% #todos Verified?"}

        TodosCheck -->|No| Phase1
        TodosCheck -->|Yes| Phase3

        Phase3[Phase 3: Termination and Memory Injection]
        Phase3 --> P3a[Zero-Defect Validation at Target Fidelity]
        Phase3 --> P3b[Context Synchronization: AGENTS.md / AGENTS.mmd / SKILL.md Sync]
        Phase3 --> P3c[Commit-Message Resolution Summary]
    end

    subgraph GLOBAL_PROTOCOLS [Global Protocols: AGENTS.mmd & docs/FLOWS.mmd]
        direction TB
        TL{Traffic Light Classification}

        subgraph Mandatory_Facts_Loading_Protocol
            FL1[Locate docs/FACTS.mmd in Repo] --> FL2{docs/FACTS.mmd Exists?}
            FL2 -->|Yes| FL3[Parse Project Facts & Invariants]
            FL3 --> FL4[Inject Core Context into Working Memory]
            FL2 -->|No| FL5[Proceed Without Canonical Facts]
            FL4 --> FL6[Align Strategy with Project Facts]
            FL5 --> FL6
        end

        subgraph Mandatory_Constraints_Loading_Protocol
            CL1[Locate CONSTRAINTS.mzn in Repo] --> CL2{CONSTRAINTS.mzn Exists?}
            CL2 -->|Yes| CL3[Parse Project Constraints & Invariants]
            CL3 --> CL4[Inject Core Logic Context into Working Memory]
            CL2 -->|No| CL5[Proceed Without Constraint Bounds]
            CL4 --> CL6[Align Execution Bounds with Restrictions]
            CL5 --> CL6
        end

        subgraph Mandatory_Instructions_Loading_Protocol
            IL1[Scan Context for .instructions.md] --> IL2{Instructions Found?}
            IL2 -->|Yes| IL3[Match Context to Instruction Scope]
            IL3 --> IL4[Read Relevant .instructions.md Files]
            IL2 -->|No| IL5[Proceed Without Domain Instructions]
            IL4 --> IL6[Apply Instruction Rules to Execution]
            IL5 --> IL6
        end

        subgraph Mandatory_Skill_Loading_Protocol
            SL1[Check .github/skills/AGENTS.md] --> SL2{Skills Found?}
            SL2 -->|Yes| SL3[Route Intent: Match Skill Name/Alias/Keyword]
            SL2 -->|No| SL6[Proceed Without Skill]
            SL3 --> SL4{Multiple Matches?}
            SL4 -->|Yes| SL5[Load Non-Overlapping or Most Specific]
            SL4 -->|No| SL5
            SL5 --> SL7[Read Best-Matching SKILL.md Files]
            SL7 --> SL8[Proceed with Execution]
            SL6 --> SL8
        end

        subgraph Extrinsic_Escalation_Protocol [Extrinsic Escalation Protocol: 10-Point Gate]
            direction TB
            EE_Trig{Trigger Extrinsic Escalation}
            EE_Trig -->|Missing API/Auth| EE1[Credential Lock]
            EE_Trig -->|Structural Obj Complete| EE2[Milestone Validation]
            EE_Trig -->|Quota/Hardware/Perms| EE3[Environment Hard-Block]
            EE_Trig -->|Logical Impossibility| EE4[Requirement Contradiction]
            EE_Trig -->|Exhausted Clarification| EE5[Irresolvable Ambiguity]
            EE_Trig -->|All Avenues Failed| EE6[Vector Exhaustion]
            EE_Trig -->|Deep Architectural Fork| EE7[High-Stakes Trade-Off]
            EE_Trig -->|Force-Push/Data Mutation| EE8[Destructive Confirmation]
            EE_Trig -->|Intractable Critical Bug| EE9[Persistent Regression]
            EE_Trig -->|Restrictive Egress Block| EE10[Network/Firewall Isolation]
        end

        EE1 & EE2 & EE3 & EE4 & EE5 & EE6 & EE7 & EE8 & EE9 & EE10 --> Escalate[Extrinsic Escalation: 10-Point Gate]
    end

    P0f --> TL
    TL -->|Green: Autonomous| Phase1
    TL -->|Yellow: Collaborative| EscalateGate{Escalation Required?}
    EscalateGate -->|Yes| EE_Trig
    Escalate -->|User Input Received| Phase1
    EscalateGate -->|No| Phase1

    EscalateCheck -->|Yes| EE_Trig
    EscalateCheck -->|No| Phase2

    P3c --> End([Objective Complete])

    subgraph Guardrails [Continuous Guardrails]
        direction TB
        G1[Anti-Premature Termination]
        G2[Explicit Tokenization: No Mental Leaps]
        G3[Trust-but-Verify Protocol]
        G4[Draft vs Committed State Firewall]
        G5[Fix-Over-Create Bias]
        G6[Zero-Trust Security Envelope]
        G7[Two-Hats Discipline: Feature XOR Refactor]
    end

    P1a -.->|governed by| G1
    P1d -.->|governed by| G3
    P2c -.->|governed by| G6
    Rewind -.->|governed by| G2

