flowchart TD
    Start([Activation]) --> Boot[Initialization Sequence]

    subgraph GLOBAL_AGENTS_md [AGENTS.md: Global Contract]
        direction TB
        B1["1- Agent Contract Alignment"] --> B2
        B2["2- Skill & Instruction Loading"]
        B3{"3- Submodules Initialized?"}
        B3 -->|No| B3a["git submodule update --init"]
        B3a --> B2
        B2 --> FL1
        FL6 --> CL1
        CL6 --> IL1
        IL6 --> SL1
        SL8 --> B3
    end

    Boot --> GLOBAL_AGENTS_md
    GLOBAL_AGENTS_md --> B4

    subgraph LOCAL_CONTRACT [tester.agent.md: Local Framework]
        B4["4- Context Verification"]
        B5["5- Emit Boot Report"]
        B5 --> Idle
        Idle{"6- Await Testing Target"}

        Idle -->|Code/Feature Input| Phase0[Phase 0: Pre-Execution Audit]

        Phase0 --> T_Audit["Adversarial Testability Review"]
        T_Audit -->|Fail| RefactorReq["Reject: Code Not Testable"]
        T_Audit -->|Pass| Phase1[Phase 1: Test-Driven Lifecycle]

        RefactorReq --> Phase3

        Phase1 --> TDD_Red["1. Assert the Gap (Write Failing Test)"]
        TDD_Red --> TDD_Dim["2. Dimensional Scaling (Scale Boundaries/Errors)"]
        TDD_Dim --> TDD_Exec{"Execute Test Suite"}

        TDD_Exec -->|Passes Intentionally| TDD_Green["3. Resolve the Gap (Green)"]
        TDD_Exec -->|Fails/Flaky| Signal["Signal Extraction & Flakiness Eradication"]
        Signal --> TDD_Exec

        TDD_Green --> Phase2[Phase 2: Quality & Security Gates]

        Phase2 --> Q_Mock["Boundary Mocking Verification"]
        Q_Mock --> Q_Iso["Non-Destructive Isolation Check"]
        Q_Iso --> Q_Cov["Behavior vs Coverage Check"]

        Q_Cov --> Phase3[Phase 3: Output & Closure]
        Phase3 --> Finalize["Format Trace & Summarize Permutations"]
        Finalize --> Output["Finalize Test Engineering Action"]
    end

    Output --> End([Objective Complete])

    Phase1 --> Phase2

    subgraph Invariants ["Testing Invariants"]
        direction TB
        I1["Genuine Falsifiability (Tests Must Fail First)"]
        I2["Behavior Over Implementation"]
        I3["Boundary Mocking Constraint"]
        I4["Realistic Data Modeling"]
        I5["Non-Destructive Execution"]
    end

    TDD_Red -.->|governed by| I1
    Q_Cov -.->|governed by| I2
    Q_Mock -.->|governed by| I3
    TDD_Dim -.->|governed by| I4
    Q_Iso -.->|governed by| I5

